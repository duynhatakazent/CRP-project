    { "source": "/signup", "destination": "/signup/index.html" },
    { "source": "/home", "destination": "/home/project.html" },
    { "source": "/about", "destination": "/about/about.html" },
    { "source": "/setting", "destination": "/setting/setting.html" }
  ]
}
